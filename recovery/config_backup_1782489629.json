{
    "app_name": "StockPilot AI",
    "version": "1.0.0",
    "debug_mode": false,
    "default_workspace": "Default",
    "max_threads": 8,
    "restore_workspace": true,
    "show_welcome": true,
    "check_updates": true,
    "cache_mb": 512,
    "hw_accel": false,
    "verbose_logging": false,
    "theme": "Dark (Default)",
    "accent_index": 0,
    "ui_font_size": 10,
    "editor_font_size": 12,
    "ui_density": "Comfortable",
    "animations": true,
    "extended_tooltips": true,
    "show_breadcrumb": true,
    "language": "English (US)",
    "date_format": "DD/MM/YYYY",
    "decimal_format": 0,
    "default_workspace_dir": "D:\\StockPilot AI\\workspaces",
    "recent_workspaces_count": 10,
    "autosave_enabled": true,
    "autosave_interval_min": 5,
    "backup_on_close": true,
    "max_backups": 5,
    "openai_api_key": "",
    "gemini_api_key": "",
    "groq_api_key": "",
    "deepseek_api_key": "",
    "openrouter_api_key": "",
    "shutterstock_api_key": "",
    "adobe_api_key": "",
    "getty_api_key": "",
    "active_marketplaces": [
        "Shutterstock",
        "Adobe Stock"
    ],
    "default_category": "Nature",
    "min_price": 0.0,
    "default_exclusive": false,
    "prompt_profiles": {
        "Standard Description": "Write a concise, professional stock photo description for the following image. Focus on subject, mood, lighting, and commercial appeal. Maximum 200 words.",
        "SEO-Optimised Title": "Generate a compelling, keyword-rich title for this stock photo. Title should be descriptive, searchable, and under 70 characters.",
        "Keyword Extraction": "Extract 30\u201350 highly relevant, commercially valuable keywords for this stock photo. Include subjects, concepts, colours, mood, and use cases. Output as a comma-separated list."
    },
    "batch_size": 50,
    "concurrent_ai_requests": 3,
    "ai_request_delay": 0.5,
    "priority_boost": false,
    "thumbnail_size": 128,
    "lazy_load_images": true,
    "preload_metadata": true,
    "log_level": "INFO",
    "log_to_file": true,
    "log_to_console": true,
    "max_log_size_mb": 10,
    "log_backup_count": 5,
    "auto_backup": false,
    "backup_frequency": "Daily",
    "keep_backups": 1,
    "backup_dir": "D:\\StockPilot AI\\recovery"
}